# ── WTO Timeseries API ──────────────────────────────────────────────────────
# Required for Trade in IP Services data (ITS_CS_AX6, ITS_CS_AM6)
# Register at: https://api.wto.org/
WTO_API_KEY=your_wto_api_key_here

# ── WIPO IPSTATS API ────────────────────────────────────────────────────────
# Base URL for WIPO IP Statistics REST API (change if WIPO updates endpoint)
WIPO_API_BASE=https://www.wipo.int/ipstats/api/data

# ── Cache settings ──────────────────────────────────────────────────────────
# Directory for raw API response cache (relative to project root)
DATA_RAW_DIR=data/raw

# Streamlit cache TTL in seconds (default: 1 hour)
CACHE_TTL_SECONDS=3600
